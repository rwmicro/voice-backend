# Docker user permissions (will be auto-set on first run)
# Run: echo "UID=$(id -u)" > .env && echo "GID=$(id -g)" >> .env
UID=1000
GID=1000

# Server Configuration
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO

# TTS Configuration
TTS_DEFAULT_PROVIDER=kokoro
TTS_DEVICE=auto
TTS_USE_FP16=true

# STT Configuration
STT_MODEL=openai/whisper-small
STT_DEVICE=auto
STT_USE_FP16=true

# GPU Queue Management (optional)
ENABLE_GPU_QUEUE=false
