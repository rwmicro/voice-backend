# ===========================
# Voice Backend Configuration
# ===========================

# TTS Configuration
TTS_DEFAULT_PROVIDER=kokoro
TTS_USE_FP16=true

# Provider-specific settings
KOKORO_MODEL=hexgrad/Kokoro-82M
CHATTERBOX_MODEL=resemble-ai/chatterbox
F5_TTS_MODEL=f5-tts

# STT Configuration
STT_MODEL=openai/whisper-small
STT_USE_FP16=true

# GPU Management
ENABLE_GPU_QUEUE=false
GPU_MAX_VRAM_MB=6000
GPU_IDLE_TIMEOUT_SECONDS=300

# Ollama Coordination (if ENABLE_GPU_QUEUE is true)
OLLAMA_BASE_URL=http://localhost:11434

# Audio Configuration
SAMPLE_RATE=24000
CHUNK_SIZE=1024
AUDIO_FORMAT=wav

# Data Paths
DATA_DIR=./data
VOICE_CACHE_DIR=./data/voice_cache
AUDIO_PROMPTS_DIR=./voice/audio_prompts

# Logs
LOG_DIR=./logs
LOG_FILE=./logs/voice-backend.log

# Performance
MAX_WORKERS=4